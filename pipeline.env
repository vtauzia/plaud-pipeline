# Environment variables for the Plaud pipeline
# This file is read by systemd before each run.

# ── Google Drive ──────────────────────────────────────────────────────────────
# The ID at the end of your Drive folder URL:
# https://drive.google.com/drive/folders/THIS_PART
GDRIVE_FOLDER_ID=YOUR_FOLDER_ID_HERE
 
# Path to the OAuth2 credentials and token files
GDRIVE_CREDS_FILE=/plaud/credentials.json
GDRIVE_TOKEN_FILE=/plaud/token.json
 
# ── Plaud bearer token (if not hardcoded in copy_plaud_recording.py) ──────────
# PLAUD_TOKEN=your_bearer_token_here
